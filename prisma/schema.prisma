generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Owner {
  id                   String                 @id @default(cuid()) @map("_id")
  email                String                 @unique
  password             String
  name                 String
  phone                String?
  isAdmin              Boolean                @default(false)
  companies            Company[]
  memberships          CompanyMember[]
  sentInvites          CompanyInvite[]        @relation("InvitesSent")
  appCollaborations    AppCollaborator[]
  sentCollabInvites    AppCollaboratorInvite[] @relation("CollabInvitesSent")
  transferRequests     AppTransferRequest[]   @relation("TransferRequests")
  auditActions         AppAuditLog[]          @relation("AuditActor")
  appUsersCreated      AppUser[]              @relation("AppUserCreator")
  createdAt            DateTime               @default(now())
}

model Company {
  id               String              @id @default(cuid()) @map("_id")
  name             String
  cnpj             String?
  cpf              String?
  logoUrl          String?
  description      String?
  apiKeyHash       String?
  ownerId          String
  owner            Owner               @relation(fields: [ownerId], references: [id])
  apps             OAuthApp[]
  members          CompanyMember[]
  invites          CompanyInvite[]
  transferRequests AppTransferRequest[]
  webhooks         Webhook[]
  createdAt        DateTime            @default(now())
}

model CompanyMember {
  id        String   @id @default(cuid()) @map("_id")
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([companyId, ownerId])
}

model CompanyInvite {
  id          String   @id @default(cuid()) @map("_id")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String
  status      String   @default("pending")
  fromOwnerId String
  fromOwner   Owner    @relation("InvitesSent", fields: [fromOwnerId], references: [id], onDelete: Cascade)
  toEmail     String
  createdAt   DateTime @default(now())
}

model OAuthApp {
  id                    String                  @id @default(cuid()) @map("_id")
  name                  String
  logoUrl               String?
  description           String?
  clientId              String                  @unique
  clientSecret          String
  redirectUris          String[]
  scopes                String[]
  tenantSlug            String?
  applyTenantAfterLogin Boolean                 @default(false)
  defaultRedirectUri    String?
  // Domínio-base onde o tenant é aplicado como subdomínio (ex.:
  // "primevisita.com.br" → "teste.primevisita.com.br"). Quando não
  // definido, cai no comportamento antigo de prefixar o host do
  // redirect_uri padrão — o que produz resultados errados quando esse
  // host já tem seu próprio subdomínio (ex.: "app.primevisita.com.br"
  // viraria "teste.app.primevisita.com.br").
  tenantDomain          String?
  companyId             String
  company               Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users                 AppUser[]
  codes                 AuthorizationCode[]
  tokens                AccessToken[]
  refreshTokens         RefreshToken[]
  authEvents            AuthEvent[]
  collaborators         AppCollaborator[]
  collabInvites         AppCollaboratorInvite[]
  transferRequests      AppTransferRequest[]
  auditLogs             AppAuditLog[]
  createdAt             DateTime                @default(now())
}

model AppCollaborator {
  id               String   @id @default(cuid()) @map("_id")
  appId            String
  app              OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  ownerId          String
  owner            Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  canViewAnalytics Boolean  @default(true)
  canCreateUsers   Boolean  @default(false)
  canEditUsers     Boolean  @default(false)
  canDeleteUsers   Boolean  @default(false)
  maxUsers         Int?
  createdAt        DateTime @default(now())

  @@unique([appId, ownerId])
}

model AppCollaboratorInvite {
  id          String   @id @default(cuid()) @map("_id")
  appId       String
  app         OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  toEmail     String
  status      String   @default("pending")
  fromOwnerId String
  fromOwner   Owner    @relation("CollabInvitesSent", fields: [fromOwnerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([appId, toEmail])
}

model AppUser {
  id                 String               @id @default(cuid()) @map("_id")
  username           String
  password           String
  name               String
  appId              String
  app                OAuthApp             @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdByOwnerId   String?
  createdByOwner     Owner?               @relation("AppUserCreator", fields: [createdByOwnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mustChangePassword Boolean              @default(false)
  codes              AuthorizationCode[]
  tokens             AccessToken[]
  refreshTokens      RefreshToken[]
  resetTokens        PasswordResetToken[]
  authEvents         AuthEvent[]
  createdAt          DateTime             @default(now())

  @@unique([username, appId])
}

model AppAuditLog {
  id         String   @id @default(cuid()) @map("_id")
  appId      String
  app        OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  actorId    String
  actor      Owner    @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  targetId   String?
  targetName String?
  meta       String?
  createdAt  DateTime @default(now())
}

model AuthEvent {
  id        String   @id @default(cuid()) @map("_id")
  appId     String
  app       OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  appUserId String?
  appUser   AppUser? @relation(fields: [appUserId], references: [id], onDelete: NoAction)
  event     String
  ip        String?
  createdAt DateTime @default(now())
}

model AuthorizationCode {
  id                  String   @id @default(cuid()) @map("_id")
  codeHash            String   @unique
  appUserId           String
  appUser             AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  appId               String
  app                 OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  redirectUri         String
  scope               String
  codeChallenge       String?
  codeChallengeMethod String?
  used                Boolean  @default(false)
  expiresAt           DateTime
  createdAt           DateTime @default(now())
}

model AccessToken {
  id        String   @id @default(cuid()) @map("_id")
  jti       String   @unique
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  appId     String
  app       OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  scope     String
  revoked   Boolean  @default(false)
  expiresAt DateTime
}

model RefreshToken {
  id        String   @id @default(cuid()) @map("_id")
  tokenHash String   @unique
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  appId     String
  app       OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  scope     String
  revoked   Boolean  @default(false)
  expiresAt DateTime
}

model PasswordResetToken {
  id        String   @id @default(cuid()) @map("_id")
  tokenHash String   @unique
  appUserId String
  appUser   AppUser  @relation(fields: [appUserId], references: [id], onDelete: Cascade)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AppTransferRequest {
  id              String   @id @default(cuid()) @map("_id")
  appId           String
  app             OAuthApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  fromCompanyId   String
  toCompanyId     String
  toCompany       Company  @relation(fields: [toCompanyId], references: [id], onDelete: Cascade)
  requestedById   String
  requestedBy     Owner    @relation("TransferRequests", fields: [requestedById], references: [id], onDelete: Cascade)
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  @@unique([appId])
}

model Webhook {
  id        String   @id @default(cuid()) @map("_id")
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BlockedTenant {
  id        String   @id @default(cuid()) @map("_id")
  slug      String   @unique
  reason    String?
  createdAt DateTime @default(now())
}
